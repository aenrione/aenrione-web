---
import ArchivePanel from "@components/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getCurrentLanguageFromUrl } from "@utils/language-utils";
import { getSortedPostsList } from "../utils/content-utils";

export const prerender = false;

const currentLanguage = getCurrentLanguageFromUrl(Astro.url);
const sortedPostsList = await getSortedPostsList(currentLanguage);
---

<MainGridLayout title={i18n(I18nKey.archive)}>
    <ArchivePanel sortedPosts={sortedPostsList} client:only="svelte"></ArchivePanel>
</MainGridLayout>
